#!/usr/bin/env php
<?php

declare(strict_types=1);

use App\Core\Config;
use App\Core\Database;
use App\Core\Env;
use App\Core\FeatureFlags;
use App\Core\Migrator;
use App\Mail\ArrayMailer;
use App\Mail\Mailer;
use App\Mail\SendmailMailer;
use App\Repository\BadgeRepository;
use App\Repository\EmailDeliveryRepository;
use App\Repository\EmailSuppressionRepository;
use App\Repository\PostRepository;
use App\Repository\ServiceSecretRepository;
use App\Repository\SettingRepository;
use App\Repository\UserRepository;
use App\Repository\WebhookDeliveryRepository;
use App\Repository\WebhookRepository;
use App\Security\EgressGuard;
use App\Security\SecretBox;
use App\Service\Webhook\CurlWebhookTransport;
use App\Service\BadgeService;
use App\Service\RepairService;
use App\Service\ReputationLedgerService;
use App\Service\SecretVault;
use App\Repository\AttachmentRepository;
use App\Repository\ModerationLogRepository;
use App\Service\AttachmentService;
use App\Support\UpgradeRehearsal;
use App\Worker\DailyDigestWorker;
use App\Worker\WebhookDeliveryWorker;
use App\Worker\IpRetentionPurger;
use App\Worker\NotificationEmailWorker;
use App\Worker\OrphanAttachmentCleaner;

$root = dirname(__DIR__);
require $root . '/vendor/autoload.php';

Env::load($root . '/.env');
$config = Config::fromFile($root . '/config/config.php');

$command = $argv[1] ?? 'help';
$log = static fn (string $m): int => fwrite(STDOUT, $m . PHP_EOL);

/** Build a Migrator bound to the configured database. */
$migrator = static function () use ($config): Migrator {
    $db = new Database($config->get('db'));
    return new Migrator($db->pdo(), $config->get('paths.migrations'));
};

/** A Database bound to the configured database. */
$database = static fn (): Database => new Database($config->get('db'));

/** Build the configured mail transport (matches App::buildContainer). */
$mailer = static function () use ($config): Mailer {
    $mail = (array) $config->get('mail', []);
    if (($mail['driver'] ?? 'sendmail') === 'array') {
        return new ArrayMailer();
    }
    $fromName = (string) ($mail['from_name'] ?? '');
    if ($fromName === '') {
        try {
            $fromName = (new SettingRepository(new Database($config->get('db'))))
                ->getString('site_name', (string) $config->get('app.name', 'RetroBoards'));
        } catch (Throwable) {
            $fromName = (string) $config->get('app.name', 'RetroBoards');
        }
    }
    return new SendmailMailer((string) ($mail['from'] ?? ''), $fromName);
};

try {
    switch ($command) {
        case 'migrate':
            $n = $migrator()->migrate($log);
            $log($n === 0 ? 'Nothing to migrate.' : "Applied $n migration(s).");
            break;

        case 'migrate:fresh':
        case 'fresh':
            $n = $migrator()->fresh($log);
            $log("Fresh database. Applied $n migration(s).");
            break;

        case 'migrate:rollback':
            $n = $migrator()->rollback($log);
            $log("Rolled back $n migration(s).");
            break;

        case 'migrate:status':
            foreach ($migrator()->status() as $name => $applied) {
                $log(sprintf('  [%s] %s', $applied ? 'x' : ' ', $name));
            }
            break;

        case 'key:generate':
            $log('APP_KEY=' . bin2hex(random_bytes(32)));
            break;

        case 'repair':
        case 'repair:all':
            $result = (new RepairService($database(), (int) $config->get('community.solved_bonus', 5)))->repairAll();
            foreach ($result as $name => $rows) {
                $log(sprintf('  repaired %-18s (%d rows)', $name, $rows));
            }
            $log('Counter reconciliation complete.');
            break;

        case 'repair:counters':
            $svc = new RepairService($database());
            $svc->repairUserPostCounts();
            $svc->repairThreadCounters();
            $svc->repairBoardCounters();
            $log('Post/thread/board counters reconciled.');
            break;

        case 'repair:reputation':
            $svc = new RepairService($database(), (int) $config->get('community.solved_bonus', 5));
            $svc->repairReputation();
            $log('Reputation ledger rebuilt and users.reputation reconciled.');
            break;

        case 'repair:reputation-ledger':
        case 'reputation:reconcile':
            $db = $database();
            $stats = (new ReputationLedgerService($db, new UserRepository($db)))
                ->rebuildFromCanonical((int) $config->get('community.solved_bonus', 5));
            foreach ($stats as $name => $rows) {
                $log(sprintf('  %-28s %d', $name . ':', $rows));
            }
            $log('Reputation ledger rebuilt and users.reputation reconciled.');
            break;

        case 'community:backfill-badges':
            // Idempotently award auto badges (incl. anniversary) from current
            // state, without synthesising historical notifications. Safe to run
            // on a cron for the time-based Anniversary badge.
            $db = $database();
            $badges = new BadgeService(
                $db,
                new BadgeRepository($db),
                new UserRepository($db),
                null,
                (int) $config->get('community.badge_conversation_starter_threads', 10),
                (int) $config->get('community.badge_trusted_answerer_solved', 10),
                (int) $config->get('community.badge_appreciated_rep', 100),
                (int) $config->get('community.badge_well_liked_rep', 1000),
            );
            $ids = $db->fetchAll('SELECT id FROM users');
            $awarded = 0;
            foreach ($ids as $row) {
                $awarded += count($badges->evaluateForUser((int) $row['id']));
            }
            $log("Badge backfill complete: $awarded new award(s) across " . count($ids) . ' user(s).');
            break;

        case 'worker:email':
            $db = $database();
            $worker = new NotificationEmailWorker(
                new EmailDeliveryRepository($db),
                new EmailSuppressionRepository($db),
                new PostRepository($db),
                new UserRepository($db),
                $mailer(),
                $config,
                new SettingRepository($db),
            );
            $stats = $worker->run((int) ($argv[2] ?? 100));
            $log(sprintf('Instant email: sent=%d suppressed=%d failed=%d skipped=%d', $stats['sent'], $stats['suppressed'], $stats['failed'], $stats['skipped']));
            break;

        case 'worker:digest':
            $db = $database();
            $worker = new DailyDigestWorker(
                $db,
                new EmailDeliveryRepository($db),
                new EmailSuppressionRepository($db),
                $mailer(),
                $config,
                new SettingRepository($db),
            );
            $stats = $worker->run(gmdate('Y-m-d H:i:s'));
            $log(sprintf('Daily digest: sent=%d skipped_empty=%d suppressed=%d', $stats['sent'], $stats['skipped_empty'], $stats['suppressed']));
            break;

        case 'verify:upgrade':
            // Phase-1 → Phase-2 upgrade rehearsal (P2-12). DESTRUCTIVE: it DROPS
            // ALL TABLES in the target DB, so it is gated behind an env check and
            // an explicit confirmation to keep it from wiping a real database
            // (CONSOLE-1). Run it only against a throwaway/scratch database.
            $env = (string) $config->get('app.env', 'production');
            $dbName = (string) ($config->get('db')['database'] ?? '');
            $force = in_array('--force', array_slice($argv, 2), true);

            if ($env === 'production') {
                $log('Refusing: verify:upgrade DROPS ALL TABLES and APP_ENV=production.');
                $log('Point it at a throwaway database with APP_ENV!=production and re-run.');
                exit(1);
            }
            if (!$force) {
                fwrite(STDOUT, "verify:upgrade will DROP ALL TABLES in database '{$dbName}'.\n");
                fwrite(STDOUT, "Type 'yes' to confirm (or pass --force for non-interactive use): ");
                $answer = is_resource(STDIN) ? strtolower(trim((string) fgets(STDIN))) : '';
                if ($answer !== 'yes') {
                    $log('Aborted — no tables were dropped.');
                    exit(1);
                }
            }

            $db = $database();
            $log('Upgrade rehearsal against database: ' . $dbName);
            $result = (new UpgradeRehearsal($db->pdo(), $config->get('paths.migrations')))->run($log);
            $log('');
            $passed = count(array_filter($result['checks'], static fn (array $c): bool => $c['ok']));
            $log(sprintf('Result: %s (%d/%d checks passed)', $result['ok'] ? 'PASS ✓' : 'FAIL ✗', $passed, count($result['checks'])));
            if (!$result['ok']) {
                exit(1);
            }
            break;

        case 'worker:purge-ips':
            // 90-day IP-retention purge (P3-05, ADMIN §5.5). Anonymises
            // sessions.ip / posts.ip older than the retention window (override
            // the day count with the first argument). Idempotent + audited.
            $db = $database();
            $days = isset($argv[2]) ? (int) $argv[2] : (int) $config->get('retention.ip_days', 90);
            $stats = (new IpRetentionPurger($db, new ModerationLogRepository($db), $days))->run();
            $log(sprintf('IP retention purge (>%d days): sessions=%d posts=%d (cutoff %s UTC)', $stats['days'], $stats['sessions'], $stats['posts'], $stats['cutoff']));
            break;

        case 'worker:attachments':
            // Reclaim orphaned upload storage (P3-04): abandoned temp uploads
            // past their TTL + finalized media whose parent post was deleted.
            $db = $database();
            $repo = new AttachmentRepository($db);
            $svc = new AttachmentService(
                $repo,
                (string) $config->get('uploads.storage_path'),
                (int) $config->get('uploads.max_bytes', 5_242_880),
                (int) $config->get('uploads.max_width', 4096),
                (int) $config->get('uploads.max_height', 4096),
                (int) $config->get('uploads.max_pixels', 24_000_000),
                (array) $config->get('uploads.allowed_mime', []),
                (int) $config->get('uploads.min_free_bytes', 0),
            );
            $stats = (new OrphanAttachmentCleaner($repo, $svc, (int) $config->get('uploads.temp_ttl_hours', 24), (int) $config->get('uploads.deleted_grace_days', 30)))->run();
            $log(sprintf('Attachment sweep: temp=%d deleted_parent=%d', $stats['temp'], $stats['deleted_parent']));
            break;

        case 'engagement:cutover':
            // Record the Phase 2 unread cutover timestamp. Content before this
            // moment starts read; later activity uses lazy thread_user rows.
            $when = $argv[2] ?? gmdate('Y-m-d H:i:s');
            (new SettingRepository($database()))->set('engagement_cutover_at', $when);
            $log("Unread cutover set to $when UTC.");
            break;

        case 'worker:secret-prune':
            // Destroy retired service-secret versions whose grace window has
            // lapsed (B2). Ciphertext/nonce/tag are emptied; the row is kept
            // for audit (state=destroyed). Behind the rb_secret_prune lock.
            $db = $database();
            $vault = new SecretVault(
                $db,
                new ServiceSecretRepository($db),
                new SecretBox((string) $config->get('app.key', '')),
                new ModerationLogRepository($db),
                new FeatureFlags(new SettingRepository($db)),
                $config,
            );
            $destroyed = $vault->prune(isset($argv[2]) ? (int) $argv[2] : 100);
            $log(sprintf('Service-secret prune: destroyed=%d', $destroyed));
            break;

        case 'worker:webhooks':
            $db = $database();
            $vault = new SecretVault(
                $db,
                new ServiceSecretRepository($db),
                new SecretBox((string) $config->get('app.key', '')),
                new ModerationLogRepository($db),
                new FeatureFlags(new SettingRepository($db)),
                $config,
            );
            $transport = new CurlWebhookTransport(
                new EgressGuard(
                    (bool) $config->get('webhooks.allow_http', false),
                    (array) $config->get('webhooks.allowed_private_cidrs', []),
                ),
                (int) $config->get('webhooks.max_response_bytes', 65536),
            );
            $worker = new WebhookDeliveryWorker(
                new WebhookRepository($db),
                new WebhookDeliveryRepository($db),
                $vault,
                $transport,
                new FeatureFlags(new SettingRepository($db)),
                new ModerationLogRepository($db),
                $config,
            );
            $stats = $worker->run((int) ($argv[2] ?? 100));
            $log(sprintf('Webhook delivery: delivered=%d retrying=%d dead=%d skipped=%d', $stats['delivered'], $stats['retrying'], $stats['dead'], $stats['skipped']));
            break;

        case 'help':
        default:
            $log('RetroBoards console');
            $log('Usage: php bin/console <command>');
            $log('');
            $log('  migrate              Apply pending migrations');
            $log('  migrate:fresh        Drop all tables and re-migrate');
            $log('  migrate:rollback     Roll back applied migrations');
            $log('  migrate:status       Show migration status');
            $log('  key:generate         Print a fresh APP_KEY');
            $log('  repair               Reconcile all denormalised counters + reputation');
            $log('  repair:counters      Reconcile post/thread/board counters');
            $log('  repair:reputation    Rebuild reputation_events and reconcile users.reputation');
            $log('  repair:reputation-ledger  Rebuild reputation_events and reconcile users.reputation');
            $log('  community:backfill-badges  Idempotently award auto badges (run on a cron for Anniversary)');
            $log('  verify:upgrade        Rehearse a Phase-1→Phase-2 upgrade on a scratch DB (destructive)');
            $log('  engagement:cutover [UTC]  Set the unread cutover timestamp');
            $log('  worker:email [limit]  Drain the instant notification-email queue');
            $log('  worker:digest         Send due daily digests');
            $log('  worker:purge-ips [days]  Anonymise sessions.ip/posts.ip older than N days (default 90)');
            $log('  worker:attachments    Sweep orphaned/deleted-parent upload files');
            $log('  worker:secret-prune [limit]  Destroy expired retired service-secret versions (default 100)');
            $log('  worker:webhooks [limit]  Drain the webhook delivery queue');
            break;
    }
} catch (Throwable $e) {
    fwrite(STDERR, 'Error: ' . $e->getMessage() . PHP_EOL);
    exit(1);
}
