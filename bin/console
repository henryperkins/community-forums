#!/usr/bin/env php
<?php

declare(strict_types=1);

use App\Core\Config;
use App\Core\Database;
use App\Core\Env;
use App\Core\Migrator;
use App\Mail\ArrayMailer;
use App\Mail\Mailer;
use App\Mail\SendmailMailer;
use App\Repository\BadgeRepository;
use App\Repository\EmailDeliveryRepository;
use App\Repository\EmailSuppressionRepository;
use App\Repository\PostRepository;
use App\Repository\SettingRepository;
use App\Repository\UserRepository;
use App\Service\BadgeService;
use App\Service\RepairService;
use App\Worker\DailyDigestWorker;
use App\Worker\NotificationEmailWorker;

$root = dirname(__DIR__);
require $root . '/vendor/autoload.php';

Env::load($root . '/.env');
$config = Config::fromFile($root . '/config/config.php');

$command = $argv[1] ?? 'help';
$log = static fn (string $m): int => fwrite(STDOUT, $m . PHP_EOL);

/** Build a Migrator bound to the configured database. */
$migrator = static function () use ($config): Migrator {
    $db = new Database($config->get('db'));
    return new Migrator($db->pdo(), $config->get('paths.migrations'));
};

/** A Database bound to the configured database. */
$database = static fn (): Database => new Database($config->get('db'));

/** Build the configured mail transport (matches App::buildContainer). */
$mailer = static function () use ($config): Mailer {
    $mail = (array) $config->get('mail', []);
    if (($mail['driver'] ?? 'sendmail') === 'array') {
        return new ArrayMailer();
    }
    return new SendmailMailer((string) ($mail['from'] ?? ''), (string) ($mail['from_name'] ?? 'RetroBoards'));
};

try {
    switch ($command) {
        case 'migrate':
            $n = $migrator()->migrate($log);
            $log($n === 0 ? 'Nothing to migrate.' : "Applied $n migration(s).");
            break;

        case 'migrate:fresh':
        case 'fresh':
            $n = $migrator()->fresh($log);
            $log("Fresh database. Applied $n migration(s).");
            break;

        case 'migrate:rollback':
            $n = $migrator()->rollback($log);
            $log("Rolled back $n migration(s).");
            break;

        case 'migrate:status':
            foreach ($migrator()->status() as $name => $applied) {
                $log(sprintf('  [%s] %s', $applied ? 'x' : ' ', $name));
            }
            break;

        case 'key:generate':
            $log('APP_KEY=' . bin2hex(random_bytes(32)));
            break;

        case 'repair':
        case 'repair:all':
            $result = (new RepairService($database(), (int) $config->get('community.solved_bonus', 5)))->repairAll();
            foreach ($result as $name => $rows) {
                $log(sprintf('  repaired %-18s (%d rows)', $name, $rows));
            }
            $log('Counter reconciliation complete.');
            break;

        case 'repair:counters':
            $svc = new RepairService($database());
            $svc->repairUserPostCounts();
            $svc->repairThreadCounters();
            $svc->repairBoardCounters();
            $log('Post/thread/board counters reconciled.');
            break;

        case 'repair:reputation':
            $svc = new RepairService($database(), (int) $config->get('community.solved_bonus', 5));
            $svc->repairReputation();
            $svc->reputationSolvedBonus();
            $log('Reputation recomputed from reactions + solved bonuses.');
            break;

        case 'community:backfill-badges':
            // Idempotently award auto badges (incl. anniversary) from current
            // state, without synthesising historical notifications. Safe to run
            // on a cron for the time-based Anniversary badge.
            $db = $database();
            $badges = new BadgeService(
                $db,
                new BadgeRepository($db),
                new UserRepository($db),
                null,
                (int) $config->get('community.badge_conversation_starter_threads', 10),
                (int) $config->get('community.badge_trusted_answerer_solved', 10),
                (int) $config->get('community.badge_appreciated_rep', 100),
                (int) $config->get('community.badge_well_liked_rep', 1000),
            );
            $ids = $db->fetchAll('SELECT id FROM users');
            $awarded = 0;
            foreach ($ids as $row) {
                $awarded += count($badges->evaluateForUser((int) $row['id']));
            }
            $log("Badge backfill complete: $awarded new award(s) across " . count($ids) . ' user(s).');
            break;

        case 'worker:email':
            $db = $database();
            $worker = new NotificationEmailWorker(
                new EmailDeliveryRepository($db),
                new EmailSuppressionRepository($db),
                new PostRepository($db),
                new UserRepository($db),
                $mailer(),
                $config,
            );
            $stats = $worker->run((int) ($argv[2] ?? 100));
            $log(sprintf('Instant email: sent=%d suppressed=%d failed=%d skipped=%d', $stats['sent'], $stats['suppressed'], $stats['failed'], $stats['skipped']));
            break;

        case 'worker:digest':
            $db = $database();
            $worker = new DailyDigestWorker(
                $db,
                new EmailDeliveryRepository($db),
                new EmailSuppressionRepository($db),
                $mailer(),
                $config,
            );
            $stats = $worker->run(gmdate('Y-m-d H:i:s'));
            $log(sprintf('Daily digest: sent=%d skipped_empty=%d suppressed=%d', $stats['sent'], $stats['skipped_empty'], $stats['suppressed']));
            break;

        case 'engagement:cutover':
            // Record the Phase 2 unread cutover timestamp. Content before this
            // moment starts read; later activity uses lazy thread_user rows.
            $when = $argv[2] ?? gmdate('Y-m-d H:i:s');
            (new SettingRepository($database()))->set('engagement_cutover_at', $when);
            $log("Unread cutover set to $when UTC.");
            break;

        case 'help':
        default:
            $log('RetroBoards console');
            $log('Usage: php bin/console <command>');
            $log('');
            $log('  migrate              Apply pending migrations');
            $log('  migrate:fresh        Drop all tables and re-migrate');
            $log('  migrate:rollback     Roll back applied migrations');
            $log('  migrate:status       Show migration status');
            $log('  key:generate         Print a fresh APP_KEY');
            $log('  repair               Reconcile all denormalised counters + reputation');
            $log('  repair:counters      Reconcile post/thread/board counters');
            $log('  repair:reputation    Recompute reputation from reactions + solved bonuses');
            $log('  community:backfill-badges  Idempotently award auto badges (run on a cron for Anniversary)');
            $log('  engagement:cutover [UTC]  Set the unread cutover timestamp');
            $log('  worker:email [limit]  Drain the instant notification-email queue');
            $log('  worker:digest         Send due daily digests');
            break;
    }
} catch (Throwable $e) {
    fwrite(STDERR, 'Error: ' . $e->getMessage() . PHP_EOL);
    exit(1);
}
