      {
        "selector": "JSXOpeningElement[name.name='ThreadRow'] > JSXAttribute[name.name='authorTier'] > Literal[value!=/^(?:Member|Veteran|Loremaster|Legend)$/]",
        "message": "<ThreadRow> authorTier must be one of 'Member' | 'Veteran' | 'Loremaster' | 'Legend'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ThreadRow'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:open|solved|needs_answer|decision_made)$/]",
        "message": "<ThreadRow> status must be one of 'open' | 'solved' | 'needs_answer' | 'decision_made'."
      }
    ]
