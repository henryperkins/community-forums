#!/usr/bin/env php
<?php

declare(strict_types=1);

use App\Core\Config;
use App\Core\Database;
use App\Core\Env;
use App\Core\FeatureFlags;
use App\Core\Migrator;
use App\Core\Telemetry;
use App\Mail\ArrayMailer;
use App\Mail\Mailer;
use App\Mail\SendmailMailer;
use App\Repository\AccountDeletionRepository;
use App\Repository\BoardMemberRepository;
use App\Repository\BoardModeratorRepository;
use App\Repository\BoardRepository;
use App\Repository\EmailDomainStatusRepository;
use App\Repository\BadgeRepository;
use App\Repository\EmailDeliveryRepository;
use App\Repository\EmailSuppressionRepository;
use App\Repository\InstalledPackagePermissionRepository;
use App\Repository\InstalledPackageRepository;
use App\Repository\LocalPackageBlockRepository;
use App\Repository\PackageAdvisoryRepository;
use App\Repository\PackageHistoryRepository;
use App\Repository\PackagePublisherRepository;
use App\Repository\PackageRegistryRepository;
use App\Repository\PackageReleaseRepository;
use App\Repository\PackageReviewDecisionRepository;
use App\Repository\PackageRepository;
use App\Repository\PackageThemeRepository;
use App\Repository\PackageTransparencyLogRepository;
use App\Repository\RegistrySnapshotRepository;
use App\Repository\RegistryTrustKeyRepository;
use App\Repository\SessionRepository;
use App\Repository\PostRepository;
use App\Repository\ProtectedOwnerRepository;
use App\Repository\RoleAssignmentRepository;
use App\Repository\RoleCapabilityRepository;
use App\Repository\ServiceSecretRepository;
use App\Repository\ServerDraftRepository;
use App\Repository\ServerExtensionRepository;
use App\Repository\SettingRepository;
use App\Repository\UserRepository;
use App\Repository\WebhookDeliveryRepository;
use App\Repository\WebhookRepository;
use App\Security\EgressGuard;
use App\Security\BoardPolicy;
use App\Security\CapabilityResolver;
use App\Security\Packages\ManifestValidator;
use App\Security\Packages\PackageSecurityGate;
use App\Security\PasswordHasher;
use App\Security\ReauthGate;
use App\Security\Registry\TrustChainVerifier;
use App\Security\SecretBox;
use App\Security\WriteGate;
use App\Service\AccountLifecycleService;
use App\Service\LinkPreviewService;
use App\Service\Packages\PackageAcquisitionService;
use App\Service\Packages\PackageArtifactStore;
use App\Service\Packages\PackageHealthService;
use App\Service\Packages\PackageLifecycleService;
use App\Service\Packages\PackageUpdateService;
use App\Service\Packages\ThemeAssetScanner;
use App\Service\Packages\ThemeBuildService;
use App\Service\Packages\ThemeStateService;
use App\Service\Registry\ArrayRegistryTransport;
use App\Service\Registry\CurlRegistryTransport;
use App\Service\Registry\RegistryAdvisoryService;
use App\Service\Registry\RegistrySnapshotService;
use App\Service\Webhook\CurlWebhookTransport;
use App\Service\BadgeService;
use App\Service\RepairService;
use App\Service\ReputationLedgerService;
use App\Service\SecretVault;
use App\Repository\AttachmentRepository;
use App\Repository\ModerationLogRepository;
use App\Service\AttachmentService;
use App\Service\AttachmentScanService;
use App\Service\EmailDomainVerifier;
use App\Service\Extension\BubblewrapSandboxAdapter;
use App\Service\LegacyAuthorityProjection;
use App\Service\Phase5BudgetReportService;
use App\Service\Phase5FixtureSeeder;
use App\Service\ResolverParityService;
use App\Support\UpgradeRehearsal;
use App\Worker\DailyDigestWorker;
use App\Worker\RegistryRefreshWorker;
use App\Worker\ServerExtensionWorker;
use App\Worker\WebhookDeliveryWorker;
use App\Worker\IpRetentionPurger;
use App\Worker\NotificationEmailWorker;
use App\Worker\OrphanAttachmentCleaner;
use App\Worker\PackageHealthWorker;
use App\Worker\RelatedTopicRefreshWorker;

$root = dirname(__DIR__);
require $root . '/vendor/autoload.php';

Env::load($root . '/.env');
$config = Config::fromFile($root . '/config/config.php');

$command = $argv[1] ?? 'help';
$log = static fn (string $m): int => fwrite(STDOUT, $m . PHP_EOL);

/** Build a Migrator bound to the configured database. */
$migrator = static function () use ($config): Migrator {
    $db = new Database($config->get('db'));
    return new Migrator($db->pdo(), $config->get('paths.migrations'));
};

/** A Database bound to the configured database. */
$database = static fn (): Database => new Database($config->get('db'));

$themeState = static function (Database $db, ?Telemetry $telemetry = null) use ($config): ThemeStateService {
    return new ThemeStateService(
        $db,
        new PackageThemeRepository($db),
        new InstalledPackageRepository($db),
        new PackageRepository($db),
        new PackageReleaseRepository($db),
        new PackageArtifactStore((string) $config->get('packages.storage_path')),
        new PackageSecurityGate(new LocalPackageBlockRepository($db), new PackageAdvisoryRepository($db)),
        new ThemeBuildService($db, new PackageThemeRepository($db), new ManifestValidator(), new ThemeAssetScanner(), $telemetry),
        new WriteGate(),
        new ReauthGate(new PasswordHasher()),
        new SettingRepository($db),
        new ModerationLogRepository($db),
        new PackageHistoryRepository($db),
        $telemetry,
        (bool) $config->get('theme.safe_mode', false),
    );
};

$packageHealth = static function (Database $db, ?Telemetry $telemetry = null) use ($config, $themeState): PackageHealthService {
    return new PackageHealthService(
        $db,
        new InstalledPackageRepository($db),
        new InstalledPackagePermissionRepository($db),
        new PackageRepository($db),
        new PackageReleaseRepository($db),
        new PackageAdvisoryRepository($db),
        new LocalPackageBlockRepository($db),
        new PackageHistoryRepository($db),
        new PackageTransparencyLogRepository($db),
        new PackageArtifactStore((string) $config->get('packages.storage_path')),
        new ModerationLogRepository($db),
        $telemetry,
        $themeState($db, $telemetry),
    );
};

$domainVerifier = static fn (Database $db): EmailDomainVerifier => new EmailDomainVerifier(
    $config,
    new SettingRepository($db),
    new EmailDomainStatusRepository($db),
);

/** Build the configured mail transport (matches App::buildContainer). */
$mailer = static function () use ($config): Mailer {
    $mail = (array) $config->get('mail', []);
    if (($mail['driver'] ?? 'sendmail') === 'array') {
        return new ArrayMailer();
    }
    $fromName = (string) ($mail['from_name'] ?? '');
    if ($fromName === '') {
        try {
            $fromName = (new SettingRepository(new Database($config->get('db'))))
                ->getString('site_name', (string) $config->get('app.name', 'RetroBoards'));
        } catch (Throwable) {
            $fromName = (string) $config->get('app.name', 'RetroBoards');
        }
    }
    return new SendmailMailer((string) ($mail['from'] ?? ''), $fromName);
};

try {
    switch ($command) {
        case 'migrate':
            $n = $migrator()->migrate($log);
            $log($n === 0 ? 'Nothing to migrate.' : "Applied $n migration(s).");
            break;

        case 'migrate:fresh':
        case 'fresh':
            $n = $migrator()->fresh($log);
            $log("Fresh database. Applied $n migration(s).");
            break;

        case 'migrate:rollback':
            $n = $migrator()->rollback($log);
            $log("Rolled back $n migration(s).");
            break;

        case 'migrate:status':
            foreach ($migrator()->status() as $name => $applied) {
                $log(sprintf('  [%s] %s', $applied ? 'x' : ' ', $name));
            }
            break;

        case 'key:generate':
            $log('APP_KEY=' . bin2hex(random_bytes(32)));
            break;

        case 'repair':
        case 'repair:all':
            $db = $database();
            $result = (new RepairService($db, (int) $config->get('community.solved_bonus', 5), $themeState($db)))->repairAll();
            foreach ($result as $name => $rows) {
                $log(sprintf('  repaired %-18s (%d rows)', $name, $rows));
            }
            $log('Counter reconciliation complete.');
            break;

        case 'repair:counters':
            $svc = new RepairService($database());
            $svc->repairUserPostCounts();
            $svc->repairThreadCounters();
            $svc->repairBoardCounters();
            $log('Post/thread/board counters reconciled.');
            break;

        case 'repair:reputation':
            $svc = new RepairService($database(), (int) $config->get('community.solved_bonus', 5));
            $svc->repairReputation();
            $log('Reputation ledger rebuilt and users.reputation reconciled.');
            break;

        case 'repair:reputation-ledger':
        case 'reputation:reconcile':
            $db = $database();
            $stats = (new ReputationLedgerService($db, new UserRepository($db)))
                ->rebuildFromCanonical((int) $config->get('community.solved_bonus', 5));
            foreach ($stats as $name => $rows) {
                $log(sprintf('  %-28s %d', $name . ':', $rows));
            }
            $log('Reputation ledger rebuilt and users.reputation reconciled.');
            break;

        case 'community:backfill-badges':
            // Idempotently award auto badges (incl. anniversary) from current
            // state, without synthesising historical notifications. Safe to run
            // on a cron for the time-based Anniversary badge.
            $db = $database();
            $badges = new BadgeService(
                $db,
                new BadgeRepository($db),
                new UserRepository($db),
                null,
                (int) $config->get('community.badge_conversation_starter_threads', 10),
                (int) $config->get('community.badge_trusted_answerer_solved', 10),
                (int) $config->get('community.badge_appreciated_rep', 100),
                (int) $config->get('community.badge_well_liked_rep', 1000),
            );
            $ids = $db->fetchAll('SELECT id FROM users');
            $awarded = 0;
            foreach ($ids as $row) {
                $awarded += count($badges->evaluateForUser((int) $row['id']));
            }
            $log("Badge backfill complete: $awarded new award(s) across " . count($ids) . ' user(s).');
            break;

        case 'worker:email':
            $db = $database();
            $worker = new NotificationEmailWorker(
                new EmailDeliveryRepository($db),
                new EmailSuppressionRepository($db),
                new PostRepository($db),
                new UserRepository($db),
                $mailer(),
                $config,
                new SettingRepository($db),
                $domainVerifier($db),
            );
            $stats = $worker->run((int) ($argv[2] ?? 100));
            $log(sprintf('Instant email: sent=%d suppressed=%d retrying=%d failed=%d skipped=%d', $stats['sent'], $stats['suppressed'], $stats['retrying'], $stats['failed'], $stats['skipped']));
            break;

        case 'worker:digest':
            $db = $database();
            $worker = new DailyDigestWorker(
                $db,
                new EmailDeliveryRepository($db),
                new EmailSuppressionRepository($db),
                $mailer(),
                $config,
                new SettingRepository($db),
                $domainVerifier($db),
            );
            $stats = $worker->run(gmdate('Y-m-d H:i:s'));
            $log(sprintf('Daily digest: sent=%d skipped_empty=%d suppressed=%d', $stats['sent'], $stats['skipped_empty'], $stats['suppressed']));
            break;

        case 'verify:upgrade':
            // Phase-1 → Phase-2 upgrade rehearsal (P2-12). DESTRUCTIVE: it DROPS
            // ALL TABLES in the target DB, so it is gated behind an env check and
            // an explicit confirmation to keep it from wiping a real database
            // (CONSOLE-1). Run it only against a throwaway/scratch database.
            $env = (string) $config->get('app.env', 'production');
            $dbName = (string) ($config->get('db')['database'] ?? '');
            $force = in_array('--force', array_slice($argv, 2), true);

            if ($env === 'production') {
                $log('Refusing: verify:upgrade DROPS ALL TABLES and APP_ENV=production.');
                $log('Point it at a throwaway database with APP_ENV!=production and re-run.');
                exit(1);
            }
            if (!$force) {
                fwrite(STDOUT, "verify:upgrade will DROP ALL TABLES in database '{$dbName}'.\n");
                fwrite(STDOUT, "Type 'yes' to confirm (or pass --force for non-interactive use): ");
                $answer = is_resource(STDIN) ? strtolower(trim((string) fgets(STDIN))) : '';
                if ($answer !== 'yes') {
                    $log('Aborted — no tables were dropped.');
                    exit(1);
                }
            }

            $db = $database();
            $log('Upgrade rehearsal against database: ' . $dbName);
            $result = (new UpgradeRehearsal($db->pdo(), $config->get('paths.migrations')))->run($log);
            $log('');
            $passed = count(array_filter($result['checks'], static fn (array $c): bool => $c['ok']));
            $log(sprintf('Result: %s (%d/%d checks passed)', $result['ok'] ? 'PASS ✓' : 'FAIL ✗', $passed, count($result['checks'])));
            if (!$result['ok']) {
                exit(1);
            }
            break;

        case 'worker:purge-ips':
            // 90-day IP-retention purge (P3-05, ADMIN §5.5). Anonymises
            // sessions.ip / posts.ip older than the retention window (override
            // the day count with the first argument). Idempotent + audited.
            $db = $database();
            $days = isset($argv[2]) ? (int) $argv[2] : (int) $config->get('retention.ip_days', 90);
            $stats = (new IpRetentionPurger($db, new ModerationLogRepository($db), $days))->run();
            $log(sprintf('IP retention purge (>%d days): sessions=%d posts=%d (cutoff %s UTC)', $stats['days'], $stats['sessions'], $stats['posts'], $stats['cutoff']));
            break;

        case 'worker:purge-accounts':
            // Grace-period account deletion (ADR 0006). Anonymises accounts whose
            // 30-day deletion-grace window has elapsed; idempotent + audited. Run
            // on the same cron cadence as the other purge workers.
            $db = $database();
            $stats = (new AccountLifecycleService(
                $db,
                new UserRepository($db),
                new AccountDeletionRepository($db),
                new SessionRepository($db),
                new ModerationLogRepository($db),
                new ServerDraftRepository($db),
                new ReauthGate(new PasswordHasher()),
            ))->purgeDue((int) ($argv[2] ?? 100));
            $log(sprintf('Account purge: anonymised %d due deletion(s).', $stats['purged']));
            break;

        case 'worker:drafts':
            // Server draft retention (ADR 0010 pull-forward). Drafts self-expire
            // on read/write, and this worker provides the operator smoke/cron path
            // for deleting rows past the 90-day retention boundary.
            $db = $database();
            $purged = (new ServerDraftRepository($db))->purgeExpired();
            $log(sprintf('Server drafts: purged_expired=%d', $purged));
            break;

        case 'worker:attachments':
            // Reclaim orphaned upload storage (P3-04): abandoned temp uploads
            // past their TTL + finalized media whose parent post was deleted.
            $db = $database();
            $repo = new AttachmentRepository($db);
            $svc = new AttachmentService(
                $repo,
                (string) $config->get('uploads.storage_path'),
                (int) $config->get('uploads.max_bytes', 5_242_880),
                (int) $config->get('uploads.max_width', 4096),
                (int) $config->get('uploads.max_height', 4096),
                (int) $config->get('uploads.max_pixels', 24_000_000),
                (array) $config->get('uploads.allowed_mime', []),
                (int) $config->get('uploads.min_free_bytes', 0),
            );
            $stats = (new OrphanAttachmentCleaner($repo, $svc, (int) $config->get('uploads.temp_ttl_hours', 24), (int) $config->get('uploads.deleted_grace_days', 30)))->run();
            $log(sprintf('Attachment sweep: temp=%d deleted_parent=%d', $stats['temp'], $stats['deleted_parent']));
            break;

        case 'worker:attachment-scans':
            // Scanner cleanup gate for expanded files: pending non-image files
            // remain undownloadable until an external scanner marks them clean.
            // This command fails stale pending rows closed so operators can recover
            // from scanner outages without serving unscanned bytes.
            $db = $database();
            $minutes = isset($argv[2]) ? (int) $argv[2] : 30;
            $stats = (new AttachmentScanService(new AttachmentRepository($db)))->cleanupStalePending($minutes);
            $log(sprintf('Attachment scan cleanup: failed=%d pending=%d', $stats['failed'], $stats['pending']));
            break;

        case 'worker:previews':
            $db = $database();
            $svc = new LinkPreviewService(
                $db,
                new PostRepository($db),
                new SettingRepository($db),
                $config,
                new EgressGuard(
                    (bool) $config->get('link_previews.allow_http', false),
                    (array) $config->get('link_previews.allowed_private_cidrs', []),
                ),
            );
            $stats = $svc->fetchQueued((int) ($argv[2] ?? 25));
            $log(sprintf('Link previews: fetched=%d blocked=%d failed=%d skipped=%d', $stats['fetched'], $stats['blocked'], $stats['failed'], $stats['skipped']));
            break;

        case 'worker:related-topics':
            $db = $database();
            $worker = new RelatedTopicRefreshWorker(
                $db,
                new FeatureFlags(new SettingRepository($db)),
            );
            $stats = $worker->run((int) ($argv[2] ?? 250));
            $log(sprintf('Related-topic refresh: linked=%d skipped=%d', $stats['linked'], $stats['skipped']));
            break;

        case 'worker:extensions':
            $db = $database();
            $flags = new FeatureFlags(new SettingRepository($db));
            $stats = (new ServerExtensionWorker(
                new ServerExtensionRepository($db),
                new BubblewrapSandboxAdapter(),
                $flags->enabled('server_extensions'),
            ))->run((int) ($argv[2] ?? 50));
            $log(sprintf(
                'Server extensions: ran=%d failed=%d skipped=%d quarantined=%d',
                $stats['ran'],
                $stats['failed'],
                $stats['skipped'],
                $stats['quarantined'],
            ));
            break;

        case 'engagement:cutover':
            // Record the Phase 2 unread cutover timestamp. Content before this
            // moment starts read; later activity uses lazy thread_user rows.
            $when = $argv[2] ?? gmdate('Y-m-d H:i:s');
            (new SettingRepository($database()))->set('engagement_cutover_at', $when);
            $log("Unread cutover set to $when UTC.");
            break;

        case 'worker:secret-prune':
            // Destroy retired service-secret versions whose grace window has
            // lapsed (B2). Ciphertext/nonce/tag are emptied; the row is kept
            // for audit (state=destroyed). Behind the rb_secret_prune lock.
            $db = $database();
            $vault = new SecretVault(
                $db,
                new ServiceSecretRepository($db),
                new SecretBox((string) $config->get('app.key', '')),
                new ModerationLogRepository($db),
                new FeatureFlags(new SettingRepository($db)),
                $config,
            );
            $destroyed = $vault->prune(isset($argv[2]) ? (int) $argv[2] : 100);
            $log(sprintf('Service-secret prune: destroyed=%d', $destroyed));
            break;

        case 'worker:webhooks':
            $db = $database();
            $vault = new SecretVault(
                $db,
                new ServiceSecretRepository($db),
                new SecretBox((string) $config->get('app.key', '')),
                new ModerationLogRepository($db),
                new FeatureFlags(new SettingRepository($db)),
                $config,
            );
            $transport = new CurlWebhookTransport(
                new EgressGuard(
                    (bool) $config->get('webhooks.allow_http', false),
                    (array) $config->get('webhooks.allowed_private_cidrs', []),
                ),
                (int) $config->get('webhooks.max_response_bytes', 65536),
            );
            $worker = new WebhookDeliveryWorker(
                new WebhookRepository($db),
                new WebhookDeliveryRepository($db),
                $vault,
                $transport,
                new FeatureFlags(new SettingRepository($db)),
                new ModerationLogRepository($db),
                $config,
            );
            $stats = $worker->run((int) ($argv[2] ?? 100));
            $log(sprintf('Webhook delivery: delivered=%d retrying=%d dead=%d skipped=%d', $stats['delivered'], $stats['retrying'], $stats['dead'], $stats['skipped']));
            break;

        case 'worker:registry-refresh':
            $db = $database();
            // Telemetry is dark unless telemetry.enabled, but wiring it here is
            // what makes the registry.refresh/snapshot/advisory events the
            // runbook points operators at actually fire on the (only) fetch path.
            $telemetry = new Telemetry($config);
            $snapshotService = new RegistrySnapshotService(
                $db,
                new TrustChainVerifier(),
                new PackageRegistryRepository($db),
                new RegistryTrustKeyRepository($db),
                new RegistrySnapshotRepository($db),
                new PackagePublisherRepository($db),
                new PackageRepository($db),
                new PackageReleaseRepository($db),
                $telemetry,
            );
            $advisoryService = new RegistryAdvisoryService(
                $db,
                new TrustChainVerifier(),
                new RegistryTrustKeyRepository($db),
                new PackageAdvisoryRepository($db),
                new PackageRepository($db),
                new PackageReleaseRepository($db),
                new ModerationLogRepository($db),
                $telemetry,
                $packageHealth($db, $telemetry),
            );
            $stats = (new RegistryRefreshWorker(
                new PackageRegistryRepository($db),
                $snapshotService,
                $advisoryService,
                new CurlRegistryTransport(
                    new EgressGuard(
                        (bool) $config->get('registry.allow_http', false),
                        (array) $config->get('registry.allowed_private_cidrs', []),
                    ),
                    (int) $config->get('registry.max_snapshot_bytes', 1_048_576),
                    (int) $config->get('registry.fetch_timeout_seconds', 10),
                ),
                (new FeatureFlags(new SettingRepository($db)))->enabled('package_registry'),
                $telemetry,
            ))->run();
            $log(sprintf(
                'Registry refresh: refreshed=%d unchanged=%d advisories=%d failed=%d skipped=%d',
                $stats['refreshed'],
                $stats['unchanged'],
                $stats['advisories'],
                $stats['failed'],
                $stats['skipped'],
            ));
            break;

        case 'worker:packages':
            $db = $database();
            $telemetry = new Telemetry($config);
            $stats = (new PackageHealthWorker(
                $packageHealth($db, $telemetry),
                (new FeatureFlags(new SettingRepository($db)))->enabled('package_registry'),
                $telemetry,
            ))->run();
            $log(sprintf(
                'packages: checked=%d quarantined=%d disabled=%d purged=%d updates=%d skipped=%d',
                $stats['checked'],
                $stats['quarantined'],
                $stats['disabled'],
                $stats['purged'],
                $stats['updates'],
                $stats['skipped'],
            ));
            break;

        case 'verify:phase5-budgets':
            // Phase 5 Foundation F9 — seeds the representative fixture (unless
            // --no-seed) and writes the A3 measured-vs-D11 budget report. Gated
            // behind an env check because it seeds data; never run against
            // production (CONSOLE-1 precedent, see verify:upgrade above).
            $env = (string) $config->get('app.env', 'production');
            if ($env === 'production') {
                $log('Refusing: verify:phase5-budgets seeds a fixture and must not run with app.env=production.');
                exit(1);
            }
            $db = $database();
            $resolver = new CapabilityResolver(
                new RoleCapabilityRepository($db),
                new RoleAssignmentRepository($db),
                new LegacyAuthorityProjection(new BoardModeratorRepository($db)),
                new ProtectedOwnerRepository($db),
                new BoardRepository($db),
                new BoardMemberRepository($db),
                new BoardPolicy(),
                new WriteGate(),
            );
            PasswordHasher::setDefaultOptions(['memory_cost' => 8, 'time_cost' => 1, 'threads' => 1]);
            $benchDir = sys_get_temp_dir() . '/rb-budget-packages-' . bin2hex(random_bytes(4));
            $benchStore = new PackageArtifactStore($benchDir);
            $acquisition = new PackageAcquisitionService(
                $db,
                new TrustChainVerifier(),
                new RegistryTrustKeyRepository($db),
                new PackageReleaseRepository($db),
                new PackageReviewDecisionRepository($db),
                new PackageTransparencyLogRepository($db),
                $benchStore,
                new ManifestValidator(),
                new ArrayRegistryTransport([]),
            );
            $securityGate = new PackageSecurityGate(
                new LocalPackageBlockRepository($db),
                new PackageAdvisoryRepository($db),
            );
            $lifecycle = new PackageLifecycleService(
                $db,
                new PackageRepository($db),
                new PackageReleaseRepository($db),
                new PackageRegistryRepository($db),
                new InstalledPackageRepository($db),
                new InstalledPackagePermissionRepository($db),
                new PackageHistoryRepository($db),
                new PackageTransparencyLogRepository($db),
                new PackageReviewDecisionRepository($db),
                $acquisition,
                $securityGate,
                $benchStore,
                new ReauthGate(new PasswordHasher()),
                new WriteGate(),
                new ModerationLogRepository($db),
                (int) $config->get('packages.retention_days', 30),
            );
            $updates = new PackageUpdateService(
                $db,
                new PackageRepository($db),
                new PackageReleaseRepository($db),
                new PackageRegistryRepository($db),
                new InstalledPackageRepository($db),
                new InstalledPackagePermissionRepository($db),
                new PackageHistoryRepository($db),
                new PackageTransparencyLogRepository($db),
                $acquisition,
                $securityGate,
                new ManifestValidator(),
                $benchStore,
                new ReauthGate(new PasswordHasher()),
                new WriteGate(),
                new ModerationLogRepository($db),
            );
            $report = new Phase5BudgetReportService($db, $resolver, new TrustChainVerifier(), $lifecycle, $updates, $benchStore);
            $path = $root . '/docs/evidence/phase5/performance-budgets.md';
            try {
                // Non-mutating: seed + measure inside a transaction that is always
                // rolled back, so the target DB (including a shared
                // retroboards_test) is left byte-for-byte unchanged. The report is
                // written from the in-memory, memoized sample after rollback.
                $pdo = $db->pdo();
                $pdo->beginTransaction();
                $reportRows = [];
                try {
                    if (!in_array('--no-seed', $argv, true)) {
                        $summary = (new Phase5FixtureSeeder($db, new SettingRepository($db), $env))->seed(true);
                        $log($summary['skipped']
                            ? 'Fixture already seeded.'
                            : sprintf('Seeded fixture (throwaway tx): %d users, %d boards, %d assignments, %d owner(s).',
                                $summary['users'], $summary['boards'], $summary['assignments'], $summary['owners']));
                    }
                    $reportRows = $report->rows(); // measures the baseline INSIDE the tx (seeded rows visible) and memoizes it
                } finally {
                    if ($pdo->inTransaction()) {
                        $pdo->rollBack();
                    }
                }
                $report->write($path); // reuses the memoized in-tx sample; no DB access, so the file is written after rollback
                foreach ($reportRows as $r) {
                    $log(sprintf('  [%-20s] %s -> %s', $r['status'], $r['key'], $r['measured']));
                }
                $log('Wrote ' . $path);
            } finally {
                foreach (glob($benchDir . '/*') ?: [] as $artifact) {
                    @unlink($artifact);
                }
                @rmdir($benchDir);
            }
            break;

        case 'verify:resolver-parity':
            // Increment 1 (P5-08): archive the old-vs-new parity corpus on the
            // F9 fixture. Seed and compare inside a rolled-back transaction; the
            // markdown is written from the in-memory result after rollback.
            $env = (string) $config->get('app.env', 'production');
            if ($env === 'production') {
                $log('Refusing: verify:resolver-parity seeds a fixture and must not run with app.env=production.');
                exit(1);
            }
            $db = $database();
            $resolver = new CapabilityResolver(
                new RoleCapabilityRepository($db),
                new RoleAssignmentRepository($db),
                new LegacyAuthorityProjection(new BoardModeratorRepository($db)),
                new ProtectedOwnerRepository($db),
                new BoardRepository($db),
                new BoardMemberRepository($db),
                new BoardPolicy(),
                new WriteGate(),
            );
            $parity = new ResolverParityService(
                $db,
                $resolver,
                new BoardModeratorRepository($db),
                new BoardMemberRepository($db),
                new ProtectedOwnerRepository($db),
                new BoardPolicy(),
                new WriteGate(),
                new SettingRepository($db),
            );
            $pdo = $db->pdo();
            $pdo->beginTransaction();
            try {
                if (!in_array('--no-seed', $argv, true)) {
                    $summary = (new Phase5FixtureSeeder($db, new SettingRepository($db), $env))->seed(true);
                    $log($summary['skipped']
                        ? 'Fixture already seeded.'
                        : sprintf('Seeded fixture (throwaway tx): %d users, %d boards, %d assignments, %d owner(s).',
                            $summary['users'], $summary['boards'], $summary['assignments'], $summary['owners']));
                }
                $result = $parity->run();
            } finally {
                if ($pdo->inTransaction()) {
                    $pdo->rollBack();
                }
            }
            $commit = trim((string) shell_exec('git -C ' . escapeshellarg($root) . ' rev-parse --short HEAD'));
            $path = $root . '/docs/evidence/phase5/resolver-parity.md';
            file_put_contents($path, $parity->render($result, $commit !== '' ? $commit : 'unknown'));
            $log(sprintf('Parity: %d tuples, %d agreed, %d mismatches.', $result['tuples'], $result['agreed'], count($result['mismatches'])));
            $log('Wrote ' . $path);
            if ($result['mismatches'] !== []) {
                foreach (array_slice($result['mismatches'], 0, 10) as $mismatch) {
                    $log(sprintf(
                        '  MISMATCH %s actor=%s target=%s legacy=%s resolver=%s (%s)',
                        $mismatch['capability'],
                        $mismatch['actor'],
                        $mismatch['target'],
                        $mismatch['legacy'] ? 'allow' : 'deny',
                        $mismatch['resolver'] ? 'allow' : 'deny',
                        $mismatch['source'],
                    ));
                }
                exit(1);
            }
            break;

        case 'help':
        default:
            $log('RetroBoards console');
            $log('Usage: php bin/console <command>');
            $log('');
            $log('  migrate              Apply pending migrations');
            $log('  migrate:fresh        Drop all tables and re-migrate');
            $log('  migrate:rollback     Roll back applied migrations');
            $log('  migrate:status       Show migration status');
            $log('  key:generate         Print a fresh APP_KEY');
            $log('  repair               Reconcile all denormalised counters + reputation');
            $log('  repair:counters      Reconcile post/thread/board counters');
            $log('  repair:reputation    Rebuild reputation_events and reconcile users.reputation');
            $log('  repair:reputation-ledger  Rebuild reputation_events and reconcile users.reputation');
            $log('  community:backfill-badges  Idempotently award auto badges (run on a cron for Anniversary)');
            $log('  verify:upgrade        Rehearse a Phase-1→Phase-2 upgrade on a scratch DB (destructive)');
            $log('  engagement:cutover [UTC]  Set the unread cutover timestamp');
            $log('  worker:email [limit]  Drain the instant notification-email queue');
            $log('  worker:digest         Send due daily digests');
            $log('  worker:drafts         Purge expired server-side drafts');
            $log('  worker:purge-ips [days]  Anonymise sessions.ip/posts.ip older than N days (default 90)');
            $log('  worker:purge-accounts [limit]  Anonymise accounts whose 30-day deletion grace has elapsed');
            $log('  worker:attachments    Sweep orphaned/deleted-parent upload files');
            $log('  worker:attachment-scans [minutes]  Fail stale expanded-file scans closed');
            $log('  worker:previews [limit]  Fetch queued allowlisted link-preview metadata');
            $log('  worker:related-topics [limit]  Refresh deterministic tag-related topic links');
            $log('  worker:extensions [limit]  Drain queued async server-extension jobs when enabled');
            $log('  worker:secret-prune [limit]  Destroy expired retired service-secret versions (default 100)');
            $log('  worker:webhooks [limit]  Drain the webhook delivery queue');
            $log('  worker:registry-refresh  Fetch + verify enabled package-registry snapshots/advisories (no-op while dark)');
            $log('  worker:packages       Verify installed package digests, enforce advisories/blocklist, purge lapsed uninstalls');
            $log('  verify:phase5-budgets   Seed the F9 fixture and write the D11 budget report (A3)');
            $log('  verify:resolver-parity  Archive the Inc-1 resolver parity corpus (exit 1 on mismatch)');
            break;
    }
} catch (Throwable $e) {
    fwrite(STDERR, 'Error: ' . $e->getMessage() . PHP_EOL);
    exit(1);
}
