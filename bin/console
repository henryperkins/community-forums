#!/usr/bin/env php
<?php

declare(strict_types=1);

use App\Core\Config;
use App\Core\Database;
use App\Core\Env;
use App\Core\Migrator;

$root = dirname(__DIR__);
require $root . '/vendor/autoload.php';

Env::load($root . '/.env');
$config = Config::fromFile($root . '/config/config.php');

$command = $argv[1] ?? 'help';
$log = static fn (string $m): int => fwrite(STDOUT, $m . PHP_EOL);

/** Build a Migrator bound to the configured database. */
$migrator = static function () use ($config): Migrator {
    $db = new Database($config->get('db'));
    return new Migrator($db->pdo(), $config->get('paths.migrations'));
};

try {
    switch ($command) {
        case 'migrate':
            $n = $migrator()->migrate($log);
            $log($n === 0 ? 'Nothing to migrate.' : "Applied $n migration(s).");
            break;

        case 'migrate:fresh':
        case 'fresh':
            $n = $migrator()->fresh($log);
            $log("Fresh database. Applied $n migration(s).");
            break;

        case 'migrate:rollback':
            $n = $migrator()->rollback($log);
            $log("Rolled back $n migration(s).");
            break;

        case 'migrate:status':
            foreach ($migrator()->status() as $name => $applied) {
                $log(sprintf('  [%s] %s', $applied ? 'x' : ' ', $name));
            }
            break;

        case 'key:generate':
            $log('APP_KEY=' . bin2hex(random_bytes(32)));
            break;

        case 'help':
        default:
            $log('RetroBoards console');
            $log('Usage: php bin/console <command>');
            $log('');
            $log('  migrate            Apply pending migrations');
            $log('  migrate:fresh      Drop all tables and re-migrate');
            $log('  migrate:rollback   Roll back applied migrations');
            $log('  migrate:status     Show migration status');
            $log('  key:generate       Print a fresh APP_KEY');
            break;
    }
} catch (Throwable $e) {
    fwrite(STDERR, 'Error: ' . $e->getMessage() . PHP_EOL);
    exit(1);
}
