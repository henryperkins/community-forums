{
    "name": "lakefrontdigital/retroboards",
    "description": "RetroBoards — self-hostable Community Inbox forum software (Phase 1 MVP backend)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "ext-curl": "*",
        "ext-dom": "*",
        "ext-gd": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-sodium": "*",
        "league/commonmark": "^2.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": false,
        "platform": {
            "php": "8.3.99"
        }
    },
    "scripts": {
        "test": "phpunit",
        "migrate": "php bin/console migrate",
        "fresh": "php bin/console migrate:fresh"
    }
}
