# RetroBoards environment configuration (copy to .env)
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000
# Optional WebAuthn relying-party id. Defaults to the APP_URL host. Set to your
# registrable domain (e.g. example.com for forum.example.com) if you want
# passkeys to survive subdomain moves. Changing it later invalidates passkeys -
# see docs/runbooks/passkeys.md before touching this.
WEBAUTHN_RP_ID=
# 32+ byte random string used to derive CSRF/guest tokens. Generate with:
#   php -r "echo bin2hex(random_bytes(32));"
APP_KEY=

# Database (MySQL 8 / MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=retroboards
DB_USERNAME=retro
DB_PASSWORD=retropw

# Session cookie. Set SESSION_SECURE=false only for local http development.
SESSION_NAME=rb_session
SESSION_SECURE=true
SESSION_LIFETIME_DAYS=30

# Send HSTS header (only meaningful over https)
SECURITY_HSTS=true

# Capability resolver posture while features.capabilities is enabled:
# shadow (default; legacy decides, mismatches -> telemetry) or enforce.
CAPABILITIES_MODE=shadow

# Thread Intelligence (AI Living Briefs — docs/runbooks/thread_intelligence.md).
# The provider credential is environment-only: never stored in the database,
# never shown in the UI, never logged. Leave empty to disable AI generation —
# manual community memory and deterministic return context keep working.
OPENAI_API_KEY=
# Model slug and reasoning effort (none|low|medium|high|max). Invalid values
# fall back to these defaults with an operator warning; nothing is clamped.
THREAD_INTELLIGENCE_MODEL=gpt-5.6-luna
THREAD_INTELLIGENCE_REASONING_EFFORT=low
# Site-wide daily budget (UTC day): generation calls and reserved input tokens.
THREAD_INTELLIGENCE_DAILY_CALL_LIMIT=100
THREAD_INTELLIGENCE_DAILY_INPUT_TOKEN_LIMIT=1000000
# Per-request ceilings. MAX_OUTPUT_TOKENS bounds reasoning + output at the API;
# the local 450-word structured-output validator is the visible-content limit.
THREAD_INTELLIGENCE_MAX_INPUT_TOKENS=32000
THREAD_INTELLIGENCE_MAX_OUTPUT_TOKENS=16000
# Transport bounds: TCP connect and full generation-request timeouts (seconds).
THREAD_INTELLIGENCE_CONNECT_TIMEOUT_SECONDS=5
THREAD_INTELLIGENCE_TIMEOUT_SECONDS=60
