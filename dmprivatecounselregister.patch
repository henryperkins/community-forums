+/* — Private-counsel signatures + register additions ————————————————————————— */
+/* Lock eyebrows (list header + conversation header) read in river ink. */
+.dm-listpane-head .eyebrow.dm-lock-eyebrow,
+.dm-thread-eyebrow { color: var(--dm-accent-ink); }
+.dm-lock-eyebrow .icon,
+.dm-thread-eyebrow .icon { width: 12px; height: 12px; color: var(--dm-accent); flex: 0 0 auto; }
+.dm-thread-eyebrow {
+    display: inline-flex;
+    align-items: center;
+    gap: 5px;
+    font-family: var(--font-label);
+    text-transform: uppercase;
+    letter-spacing: var(--tracking-caps);
+    font-size: .6rem;
+    margin: 0 0 2px;
+}
+/* Opening divider — the fastest "this is private" cue at the top of the thread. */
+.dm-day-private { gap: 9px; color: var(--dm-accent-ink); }
+.dm-day-private .icon { width: 12px; height: 12px; color: var(--dm-accent); flex: 0 0 auto; }
+
+/* Rank pill beside a group author's name — gold esteem, like the members list. */
+.dm-rank {
+    font-family: var(--font-label);
+    text-transform: uppercase;
+    letter-spacing: .04em;
+    font-size: .56rem;
+    line-height: 1.5;
+    color: var(--gold-ink);
+    background: var(--gold-100);
+    border: 1px solid var(--gold-200);
+    border-radius: var(--radius-pill);
+    padding: 1px 7px;
+}
+
+/* Quoted reply → a gold-ruled italic blockquote (from the message's markdown). */
+.dm-body blockquote {
+    margin: 4px 0;
+    padding: 2px 0 2px 14px;
+    border-left: 2px solid var(--rule-gold);
+    color: var(--text-muted);
+    font-style: italic;
+}
+.dm-group.mine .dm-body blockquote { border-left-color: var(--gold-400); }
+
+/* Conversation composer → the calm river "pill". The field sheds the gold
+   engrave for a cool rounded well and Send becomes a round action button. These
+   rules are robust to composer.js: whatever toolbar it injects sits above the
+   field (order:-1) and the counter/preview below. Only .dm-composer (the reply)
+   is repointed — the compose dialog's .dm-form fields keep their engrave. */
+.dm-composer .composer-input {
+    border: 1px solid var(--dm-accent-line);
+    border-radius: var(--radius-lg);
+    background: var(--dm-ground);
+    box-shadow: none;
+    clip-path: none;
+    padding: 10px 14px;
+    resize: none;
+}
+.dm-composer .composer-input:focus {
+    outline: 0;
+    border-color: var(--dm-accent);
+    box-shadow: var(--dm-focus-ring);
+}
+.dm-composer .composer-toolbar { order: -1; margin: 0; }
+.dm-composer .composer-count { align-self: flex-end; margin: 0; }
+.dm-composer .dm-send {
+    align-self: flex-end;
+    width: 38px;
+    height: 38px;
+    min-width: 0;
+    padding: 0;
+    margin: 0;
+    border-radius: 50%;
+    display: inline-flex;
+    align-items: center;
+    justify-content: center;
+}
+.dm-composer .dm-send .icon { width: 18px; height: 18px; }
+
 /* — Moderation: warden's table and member appeal surfaces. — */
 .mod {
     max-width: 1120px;
