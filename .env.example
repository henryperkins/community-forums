# RetroBoards environment configuration (copy to .env)
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000
# Optional WebAuthn relying-party id. Defaults to the APP_URL host. Set to your
# registrable domain (e.g. example.com for forum.example.com) if you want
# passkeys to survive subdomain moves. Changing it later invalidates passkeys -
# see docs/runbooks/passkeys.md before touching this.
WEBAUTHN_RP_ID=
# 32+ byte random string used to derive CSRF/guest tokens. Generate with:
#   php -r "echo bin2hex(random_bytes(32));"
APP_KEY=

# Database (MySQL 8 / MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=retroboards
DB_USERNAME=retro
DB_PASSWORD=retropw

# Session cookie. Set SESSION_SECURE=false only for local http development.
SESSION_NAME=rb_session
SESSION_SECURE=true
SESSION_LIFETIME_DAYS=30

# Send HSTS header (only meaningful over https)
SECURITY_HSTS=true

# Capability resolver posture while features.capabilities is enabled:
# shadow (default; legacy decides, mismatches -> telemetry) or enforce.
CAPABILITIES_MODE=shadow
